{
  "manifest_version": 3,
  "name": "Words by Funthinkers.com",
  "version": "1.1.3",
  "description": "Look up, learn, and collect words while you read.",
  "permissions": ["storage", "contextMenus", "activeTab", "scripting"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
